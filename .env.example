# Database (Supabase Postgres)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgres://postgres:postgres@localhost:5432/parsalo

# Auth
JWT_SECRET=change-me-to-a-long-random-string
OTP_DEV_MODE=true   # when true, OTP is logged and "123456" is always accepted

# Production hardening
# CORS_ORIGINS: comma-separated allow-list. Empty = allow all (dev only).
# Example for prod: https://parsalo.com,https://agent.parsalo.com,https://admin.parsalo.com
CORS_ORIGINS=
# TRUST_PROXY: set to true when API sits behind Nginx/Cloudflare so Express
# reads the real client IP from X-Forwarded-For (rate-limit + logging).
TRUST_PROXY=false
# SEED_PRODUCTION=true skips creating the test agent + dev creds during `npm run seed`.
SEED_PRODUCTION=false

# SMS (MSG91)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=PRCLPL
MSG91_TEMPLATE_ID=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=Parsalo <noreply@parsalo.in>

# Payments (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Maps
GOOGLE_MAPS_API_KEY=
# Browser-side key for the customer web app — restrict by HTTP referrer in Google Cloud console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Firebase Admin SDK — used by the API to send FCM pushes to the agent app.
# Set exactly one. Path is easiest in dev, JSON for hosts that prefer env-only.
FIREBASE_SERVICE_ACCOUNT_PATH=
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# Courier integration (Shiprocket)
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# Public
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
EXPO_PUBLIC_API_URL=http://localhost:4000/api/v1
