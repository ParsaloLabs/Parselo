# Database (Supabase Postgres)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgres://postgres:postgres@localhost:5432/parcelpal

# Auth
JWT_SECRET=change-me-to-a-long-random-string
OTP_DEV_MODE=true   # when true, OTP is logged and "123456" is always accepted

# SMS (MSG91)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=PRCLPL
MSG91_TEMPLATE_ID=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=ParcelPal <noreply@parcelpal.in>

# Payments (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Maps
GOOGLE_MAPS_API_KEY=
# Browser-side key for the customer web app — restrict by HTTP referrer in Google Cloud console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Courier integration (Shiprocket)
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# Public
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
EXPO_PUBLIC_API_URL=http://localhost:4000/api/v1
